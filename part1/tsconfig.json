  "compilerOptions": {
    "target": "ES6",
    "outDir": "./",
    "rootDir": "./",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["app.ts"],
  "exclude": ["node_modules"]
}
